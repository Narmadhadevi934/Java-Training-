class Graph_Methods {
	class Node {
		int data;
		Node next;
		Node(int data) {
			this.data = data;
		}
	}
	int size;
	Node[] arr;
	Graph_Methods(int size) {
		this.size = size;
		arr = new Node[size];
	}
	void addedge(int u, int v) {
		Node newnode = new Node(v);
		newnode.next = arr[u];
		arr[u] = newnode;
		newnode = new Node(u);
		newnode.next = arr[v];
		arr[v] = newnode;
	}
	void dfs(int start) {
		boolean visited[] = new boolean[size];
		dfs_traverse(start,visited);
	}
	void dfs_traverse(int start, boolean[] visited) {
		visited[start]=true;//visited
		System.out.print(start+" ");//print
		Node temp = arr[start];
		while(temp != null) {
			if(!visited[temp.data]) {
				dfs_traverse(temp.data, visited);
			}
			temp = temp.next;
		}


	}
	void bfs(int start) {
		boolean visited[] = new boolean[size];
		int arr1[] = new int[size];
		int front = 0, rear = 0;
		visited[start] = true;
		arr1[rear++] = start;
		while(front<rear) {
			int node = arr1[front++];
			System.out.print(node+" ");
			Node temp = arr[node];
			while(temp!=null) {
				if(!visited[temp.data]){
				    visited[temp.data] = true;
				    arr1[rear++] = temp.data;
				}
				temp = temp.next;
			}
		}
	}
}
public class Main
{
	public static void main(String[] args) {
		Graph_Methods gm = new Graph_Methods(5);
		gm.addedge(0,1);
		gm.addedge(0,2);
		gm.addedge(1,3);
		gm.addedge(1,4);
		System.out.println("DFS");
		gm.dfs(0);
		System.out.println("BFS");
		gm.bfs(0);
		//	System.out.println();
	}
}
